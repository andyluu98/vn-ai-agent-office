# Browser/client gateway URL (build-time — requires `npm run build` after changes)
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:18789

# Runtime gateway URL — takes effect on restart without a rebuild.
# Use this instead of NEXT_PUBLIC_GATEWAY_URL when you want to change the
# gateway endpoint without re-running `npm run build`.
# VN_OFFICE_GATEWAY_URL=ws://localhost:18789
# VN_OFFICE_GATEWAY_TOKEN=
# Optional: tell Studio which backend that runtime gateway URL represents.
# Valid values: openclaw, hermes, demo, custom
# VN_OFFICE_GATEWAY_ADAPTER_TYPE=openclaw
# legacy CLAW3D_* still honored as fallback
# CLAW3D_GATEWAY_URL=ws://localhost:18789
# CLAW3D_GATEWAY_TOKEN=
# CLAW3D_GATEWAY_ADAPTER_TYPE=openclaw


# HERMES_API_URL=http://localhost:8642
# HERMES_API_KEY=change-me-local-dev
# HERMES_MODEL=hermes-agent

# Debug UI
DEBUG=true

# App server
# PORT=3000
# HOST=127.0.0.1

# Optional: required only for public/remote deployments
# STUDIO_ACCESS_TOKEN=
# Advanced only: some gateway-host operations can still use SSH, but marketplace skill install does not require it.
# OPENCLAW_GATEWAY_SSH_TARGET=
# OPENCLAW_GATEWAY_SSH_USER=
# OPENCLAW_GATEWAY_SSH_PORT=
# OPENCLAW_GATEWAY_SSH_STRICT_HOST_KEY_CHECKING=accept-new

# Hermes Agent adapter (alternative to OpenClaw)
# Run `npm run hermes-adapter` to start the adapter, then connect VN AI Agent Office to ws://localhost:18789
# HERMES_API_URL=http://localhost:8642
# HERMES_API_KEY=
# HERMES_ADAPTER_PORT=18789
# HERMES_MODEL=hermes
# HERMES_AGENT_NAME=Hermes
# If VN_OFFICE_GATEWAY_URL is unset, Studio can still detect this local adapter port.

# Demo gateway (no OpenClaw or Hermes required)
# Run `npm run demo-gateway` and connect VN AI Agent Office to ws://localhost:18789
# DEMO_ADAPTER_PORT=18789
# If VN_OFFICE_GATEWAY_URL is unset, Studio can still detect this local adapter port.

# Optional: voice features
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# Claude Code runtime adapter (npm run claude-adapter)
# Auth: either be signed in to Claude Code (subscription; has a weekly limit),
# or set ANTHROPIC_API_KEY to use the pay-as-you-go API (no weekly limit).
# ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_ADAPTER_PORT=7770
CLAUDE_ADAPTER_HOST=127.0.0.1
CLAUDE_ADAPTER_MODEL=claude-haiku-4-5-20251001
# CLAUDE_BIN=claude
# CLAUDE_ADAPTER_ROSTER=/path/to/claude-agents.json
# CLAUDE_ADAPTER_VERSION=cli
# Dynamic agent registry (Phase 6)
CLAUDE_ADAPTER_MAX_AGENTS=12
# CLAUDE_ADAPTER_AGENT_TTL_MS=1800000
# Max simultaneous claude CLI processes (concurrency gate, default 4)
# CLAUDE_ADAPTER_MAX_CONCURRENT=4
# How many tasks run in_progress at once during a /command meeting (default 3).
# Must be <= CLAUDE_ADAPTER_MAX_CONCURRENT so the gate never rejects meeting tasks.
# Increase both together: e.g. MEETING_CONCURRENCY=5, MAX_CONCURRENT=6.
# CLAUDE_ADAPTER_MEETING_CONCURRENCY=3
